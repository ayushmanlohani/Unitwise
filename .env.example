# Replace this with your actual Groq API key (starts with gsk_)
GROQ_API_KEY=your_groq_api_key_here

# Comma-separated list of allowed CORS origins.
# In HF Spaces secrets, set this to your Vercel URL (and localhost for local dev).
# Example: CORS_ORIGINS=https://unitwise.vercel.app,http://localhost:3000
CORS_ORIGINS=http://localhost:3000